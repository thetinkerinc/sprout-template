{
	"name": "<<sprout-app>>",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "run-s dev:db dev:web",
		"dev:db": "docker compose up -d",
		"dev:web": "vite dev",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"cleanup": "run-s cf-typegen i18n format lint check",
		"i18n": "paraglide-js compile",
		"format": "prettier --write . '!data/**'",
		"lint": "eslint .",
		"prepare": "svelte-kit sync",
		"preview": "vite preview",
		"studio": "dotenvx run -- drizzle-kit studio",
		"cf-typegen": "wrangler types src/worker-configuration.d.ts"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.59.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.2",
		"bits-ui": "^2.16.5",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"kysely-ctl": "^0.20.0",
		"mode-watcher": "^1.1.0",
		"npm-run-all": "^4.1.5",
		"pg": "^8.20.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3",
		"wrangler": "^4.80.0"
	},
	"dependencies": {
		"@clerk/localizations": "^4.3.0",
		"@inlang/paraglide-js": "^2.15.1",
		"@thetinkerinc/commander": "^0.2.0",
		"@thetinkerinc/isolocal": "^0.1.1",
		"@thetinkerinc/sprout": "^0.5.1",
		"date-fns": "^4.1.0",
		"kysely": "^0.28.15",
		"svelte-clerk": "^1.1.1"
	}
}
